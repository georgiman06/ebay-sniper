# ── eBay OAuth2 Credentials ──────────────────────────────────────────────────
# Register your app at https://developer.ebay.com/my/keys
# Use "Production" keys (not Sandbox) for live data.
EBAY_CLIENT_ID=your-ebay-client-id-here
EBAY_CLIENT_SECRET=your-ebay-client-secret-here

# ── eBay API Endpoints ────────────────────────────────────────────────────────
EBAY_AUTH_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_BROWSE_API_URL=https://api.ebay.com/buy/browse/v1
EBAY_FINDING_API_URL=https://svcs.ebay.com/services/search/FindingService/v1
EBAY_MARKETPLACE_ID=EBAY_US

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev with docker-compose:
DATABASE_URL=postgresql://user:password@localhost:5432/ebay_deal_finder
# For Railway (injected automatically by Railway Postgres plugin):
# DATABASE_URL=postgresql://<user>:<pass>@<host>:<port>/<db>

# ── Security ──────────────────────────────────────────────────────────────────
# A secret token the frontend sends in X-API-Key header on every request.
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-strong-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your Railway frontend URL when deployed.
CORS_ORIGINS=http://localhost:3000

# ── Optional ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
GLOBAL_DEFAULT_MARGIN=0.30
TOKEN_CACHE_BUFFER_SECONDS=60
